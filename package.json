{
  "name": "horizon",
  "private": true,
  "version": "1.0.1",
  "main": "electron/dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server:dev": "tsx watch server/src/server.ts",
    "db:reset": "node scripts/reset-db.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "server:build": "tsc -p server/tsconfig.json && node scripts/copy-migrations.mjs --dest=server/dist/storage/sqlite/migrations",
    "server:bundle": "node scripts/bundle-server.mjs && node scripts/copy-migrations.mjs --dest=server/dist/migrations",
    "electron:build": "tsc -p electron && esbuild electron/preload.ts --bundle --platform=node --external:electron --outfile=electron/dist/preload.js",
    "electron:dev": "concurrently \"vite\" \"tsx watch electron/main.ts\" \"esbuild electron/preload.ts --bundle --platform=node --external:electron --outfile=electron/dist/preload.js --watch\"",
    "electron:start": "npm run electron:rebuild && npm run build && npm run electron:build && npm run server:build && cross-env HORIZON_FORCE_PROD_RENDERER=1 HORIZON_FORCE_COMPILED_SERVER=1 electron electron/dist/main.js",
    "preversion": "npm rebuild better-sqlite3 && npm test && npm run typecheck && npm run lint",
    "postversion": "git push && git push --tags",
    "release": "npm run electron:rebuild && npm run build && npm run server:bundle && npm run electron:build && electron-builder --publish always",
    "release:local": "npm run electron:rebuild && npm run build && npm run server:bundle && npm run electron:build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir --publish never"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/react-datepicker": "^6.2.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "lucide-react": "^1.8.0",
    "multer": "^2.1.1",
    "react": "^19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "styled-components": "^6.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/carlos-rezai/Horizon"
  },
  "build": {
    "appId": "io.github.carlosrezai.horizon",
    "productName": "Horizon",
    "icon": "src/assets/icon.ico",
    "files": [
      "dist/**",
      "electron/dist/**",
      "server/dist/**"
    ],
    "asarUnpack": [
      "**/*.node",
      "server/dist/**",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "carlos-rezai",
      "repo": "horizon"
    }
  }
}

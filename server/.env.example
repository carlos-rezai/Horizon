# Copy to server/.env for local development. Loaded by server/src/server.ts.
# Horizon is an offline-first desktop app — no auth, no cloud, no network.

# Port the Express server listens on (loopback only). Defaults to 3001.
PORT=3001

# Where the dev SQLite database lives. Keeps runtime DB files out of the repo
# root (they land in the gitignored .data/ dir). Unset falls back to ./horizon.db.
# In the packaged app, Electron sets this to the OS user-data dir instead.
HORIZON_DB_PATH=./.data/horizon.db

# Set to "1" to trace every SQL statement via console.info. Off by default;
# never enable in packaged builds.
# DEBUG_SQL=1

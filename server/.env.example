# Cloud Build (production / portfolio deploy)
# All three are required when AUTH_DISABLED is unset.
GOOGLE_CLIENT_ID=
OWNER_GOOGLE_SUB=

# Storage
MONGODB_URI=

# Optional rate limit on the token-verification path (Cloud Build only)
AUTH_RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# AI
GEMINI_API_KEY=

# Desktop Build (offline) — set this to disable all cloud-only middleware:
# requireOwner, helmet, the rate limiter, and the sanitizing 5xx error handler.
# Leave unset for the Cloud Build.
# AUTH_DISABLED=1
